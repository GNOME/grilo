#: libs/net/grl-net-mock.c:93
msgid "No mock definition found"
msgstr "ບໍ່ພົບຄຳນິຍາມຈຳລອງ"

#: libs/net/grl-net-mock.c:104
#, c-format
msgid "Could not find mock content %s"
msgstr "ບໍ່ສາມາດຊອກຫາເນື້ອຫາຈຳລອງ %s ໄດ້"

#: libs/net/grl-net-mock.c:121
#, c-format
msgid "Could not access mock content: %s"
msgstr "ບໍ່ສາມາດເຂົ້າເຖິງເນື້ອຫາຈຳລອງໄດ້: %s"

#: libs/net/grl-net-wc.c:465
msgid "Cannot connect to the server"
msgstr "ບໍ່ສາມາດເຊື່ອມຕໍ່ໄປຫາເຊີບເວີໄດ້"

#: libs/net/grl-net-wc.c:471
msgid "Cannot connect to the proxy server"
msgstr "ບໍ່ສາມາດເຊື່ອມຕໍ່ໄປຫາພຣັອກຊີເຊີບເວີໄດ້"

#: libs/net/grl-net-wc.c:481
#, c-format
msgid "Invalid request URI or header: %s"
msgstr "URI ຫຼືສ່ວນຫົວຂອງການຮ້ອງຂໍບໍ່ຖືກຕ້ອງ: %s"

#: libs/net/grl-net-wc.c:488
#, c-format
msgid "Authentication required: %s"
msgstr "ຕ້ອງການການຢືນຢັນຕົວຕົນ: %s"

#: libs/net/grl-net-wc.c:493
#, c-format
msgid "The requested resource was not found: %s"
msgstr "ບໍ່ພົບຊັບພະຍາກອນທີ່ຮ້ອງຂໍ: %s"

#: libs/net/grl-net-wc.c:500
#, c-format
msgid "The entry has been modified since it was downloaded: %s"
msgstr "ລາຍການນີ້ໄດ້ຖືກແກ້ໄຂແລ້ວ ນັບຕັ້ງແຕ່ໄດ້ດາວໂຫຼດມາ: %s"

#: libs/net/grl-net-wc.c:507 libs/net/grl-net-wc.c:615 libs/pls/grl-pls.c:496
#: src/grl-source.c:1821 src/grl-source.c:1921 src/grl-source.c:2068
#: src/grl-source.c:2325 src/grl-source.c:2446
#, c-format
msgid "Operation was cancelled"
msgstr "ການດຳເນີນການໄດ້ຖືກຍົກເລີກ"

#: libs/net/grl-net-wc.c:618 libs/net/grl-net-wc.c:676
msgid "Data not available"
msgstr "ບໍ່ມີຂໍ້ມູນ"

#: libs/net/grl-net-wc.c:731
#, c-format
msgid "Invalid URL %s"
msgstr "URL %s ບໍ່ຖືກຕ້ອງ"

#: src/grilo.c:218
msgid "Semicolon-separated paths containing Grilo plugins"
msgstr "ເສັ້ນທາງທີ່ບັນຈຸປລັກອິນ Grilo ໂດຍແຍກກັນດ້ວຍເຄື່ອງໝາຍຈໍ້າຈຸດ (;)"

#: src/grilo.c:220
msgid "Colon-separated paths containing Grilo plugins"
msgstr "ເສັ້ນທາງທີ່ບັນຈຸປລັກອິນ Grilo ໂດຍແຍກກັນດ້ວຍເຄື່ອງໝາຍສອງຈໍ້າ (:)"

#: src/grilo.c:223
msgid "Colon-separated list of Grilo plugins to use"
msgstr "ລາຍຊື່ປລັກອິນ Grilo ທີ່ຈະໃຊ້ ໂດຍແຍກກັນດ້ວຍເຄື່ອງໝາຍສອງຈໍ້າ (:)"

#: src/grilo.c:228
msgid "Grilo Options"
msgstr "ຕົວເລືອກ Grilo"

#: src/grilo.c:229
msgid "Show Grilo Options"
msgstr "ສະແດງຕົວເລືອກ Grilo"

#: src/grl-multiple.c:134
#, c-format
msgid "No searchable sources available"
msgstr "ບໍ່ມີແຫຼ່ງຂໍ້ມູນທີ່ສາມາດຄົ້ນຫາໄດ້"

#: src/grl-multiple.c:511
#, c-format
msgid "Could not resolve media for URI “%s”"
msgstr "ບໍ່ສາມາດແກ້ໄຂມີເດຍສຳລັບ URI “%s” ໄດ້"

#: src/grl-registry.c:499 src/grl-registry.c:1538
#, c-format
msgid "Plugin “%s” is already loaded"
msgstr "ປລັກອິນ “%s” ໄດ້ຖືກໂຫຼດໄວ້ແລ້ວ"

#: src/grl-registry.c:523
#, c-format
msgid "Failed to initialize plugin from %s"
msgstr "ລົ້ມເຫຼວໃນການເລີ່ມຕົ້ນປລັກອິນຈາກ %s"

#: src/grl-registry.c:565
#, c-format
msgid "Metadata key “%s” already registered in different format"
msgstr "ຄີເມຕາເດຕາ “%s” ໄດ້ຖືກລົງທະບຽນໄວ້ແລ້ວໃນຮູບແບບອື່ນ"

#: src/grl-registry.c:578
#, c-format
msgid "Metadata key “%s” cannot be registered"
msgstr "ບໍ່ສາມາດລົງທະບຽນຄີເມຕາເດຕາ “%s” ໄດ້"

#: src/grl-registry.c:1144
#, c-format
msgid "Source with id “%s” was not found"
msgstr "ບໍ່ພົບແຫຼ່ງຂໍ້ມູນທີ່ມີໄອດີ “%s”"

#: src/grl-registry.c:1218
#, c-format
msgid "Failed to load plugin from %s"
msgstr "ລົ້ມເຫຼວໃນການໂຫຼດປລັກອິນຈາກ %s"

#: src/grl-registry.c:1227
#, c-format
msgid "Invalid plugin file %s"
msgstr "ໄຟລ໌ປລັກອິນ %s ບໍ່ຖືກຕ້ອງ"

#: src/grl-registry.c:1238
#, c-format
msgid "“%s” is not a valid plugin file"
msgstr "“%s” ບໍ່ແມ່ນໄຟລ໌ປລັກອິນທີ່ຖືກຕ້ອງ"

#: src/grl-registry.c:1257
#, c-format
msgid "Plugin “%s” already exists"
msgstr "ປລັກອິນ “%s” ມີຢູ່ແລ້ວ"

#: src/grl-registry.c:1420
#, c-format
msgid "Invalid path %s"
msgstr "ເສັ້ນທາງ %s ບໍ່ຖືກຕ້ອງ"

#: src/grl-registry.c:1487
#, c-format
msgid "All configured plugin paths are invalid"
msgstr "ເສັ້ນທາງປລັກອິນທີ່ກຳນົດຄ່າໄວ້ທັງໝົດບໍ່ຖືກຕ້ອງ"

#: src/grl-registry.c:1527
#, c-format
msgid "Plugin “%s” not available"
msgstr "ປລັກອິນ “%s” ບໍ່ສາມາດໃຊ້ໄດ້"

#: src/grl-registry.c:1755
#, c-format
msgid "Plugin not found: “%s”"
msgstr "ບໍ່ພົບປລັກອິນ: “%s”"

#: src/grl-registry.c:2066
#, c-format
msgid "Plugin configuration does not contain “plugin-id” reference"
msgstr "ການຕັ້ງຄ່າປລັກອິນບໍ່ມີການອ້າງອີງ “plugin-id”"

#: src/grl-source.c:2775
#, c-format
msgid "Some keys could not be written"
msgstr "ບາງຄີບໍ່ສາມາດຂຽນໄດ້"

#: src/grl-source.c:2848
#, c-format
msgid "None of the specified keys are writable"
msgstr "ບໍ່ມີຄີໃດທີ່ລະບຸໄວ້ສາມາດຂຽນໄດ້"

#: src/grl-source.c:4191
#, c-format
msgid "Media has no “id”, cannot remove"
msgstr "ມີເດຍບໍ່ມີ “id”, ບໍ່ສາມາດລຶບອອກໄດ້"
